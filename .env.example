PROJECTS_DIR=/opt/wanna-cry/projects

MAX_LOG_LINES_PER_RUN=5000
LOG_RETENTION_DAYS=30
RUN_RETENTION_DAYS=90
MAINTENANCE_INTERVAL_HOURS=24

NOTIFY_WEBHOOK_URL=                          # kosong = disabled
NOTIFY_WEBHOOK_TYPE=auto                     # auto | slack | discord | generic
NOTIFY_ON=failed,timeout,canceled            # atau "all"
NOTIFY_PUBLIC_URL=                           # mis. https://wanna-cry.example.com
NOTIFY_TIMEOUT_MS=5000