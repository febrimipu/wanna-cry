<%- include('partials/header') %>
<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col">
      <h2 class="page-title">Run <%= run.id %></h2>
      <div class="text-muted mt-1"><%= run.project %> / <code><%= run.command_id %></code></div>
    </div>
    <div class="col-auto ms-auto">
      <% if ((run.status === 'queued' || run.status === 'running') && user && (user.role === 'admin' || user.role === 'operator')) { %>
        <form method="post" action="/runs/<%= run.id %>/cancel" class="d-inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>"/>
          <button class="btn btn-outline-danger" onclick="return confirm('Cancel run?')">Cancel</button>
        </form>
      <% } %>
      <a href="/runs" class="btn btn-outline-secondary">Back</a>
    </div>
  </div>
</div>

<div class="card mt-3">
  <div class="card-body">
    <div class="row">
      <div class="col-sm-3"><div class="subheader">Status</div><span class="badge bg-blue-lt"><%= run.status %></span></div>
      <div class="col-sm-3"><div class="subheader">Exit code</div><%= run.exit_code === null ? '-' : run.exit_code %></div>
      <div class="col-sm-3"><div class="subheader">Started</div><%= run.started_at || '-' %></div>
      <div class="col-sm-3"><div class="subheader">Finished</div><%= run.finished_at || '-' %></div>
    </div>
  </div>
</div>

<div class="card mt-3">
  <div class="card-header"><h3 class="card-title">Logs</h3></div>
  <div class="card-body">
    <pre id="logBox" class="bg-dark text-white p-3 rounded" style="max-height:520px;overflow:auto"><code id="logCode"><% logs.forEach(function(l){ %><%= l.ts %> [<%= l.stream %>] <%= l.chunk %>
<% }) %></code></pre>
    <div class="text-muted mt-2">Auto-refresh setiap 2s saat status <code>running</code>.</div>
  </div>
</div>

<script>
  (function () {
    const runId = <%- JSON.stringify(run.id) %>
    const status = <%- JSON.stringify(run.status) %>
    if (status !== "running") return

    const logBox = document.getElementById("logBox")
    const logCode = document.getElementById("logCode")
    let lastId = <%- JSON.stringify((logs && logs.length ? logs[logs.length - 1].id : 0) || 0) %>

    async function poll() {
      try {
        const res = await fetch(`/runs/${runId}/logs.json?after=${encodeURIComponent(lastId)}`, { credentials: "same-origin" })
        if (!res.ok) return
        const data = await res.json()
        const items = (data && data.logs) || []

        if (items.length) {
          const atBottom = Math.abs((logBox.scrollHeight - logBox.scrollTop) - logBox.clientHeight) < 8
          for (const l of items) {
            lastId = Math.max(lastId, l.id)
            logCode.textContent += `${l.ts} [${l.stream}] ${l.chunk}\n`
          }
          if (atBottom) logBox.scrollTop = logBox.scrollHeight
        }
      } catch (e) {
        // ignore
      }
    }

    setInterval(poll, 2000)
  })()
</script>
<%- include('partials/footer') %>
