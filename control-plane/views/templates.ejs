<%- include('partials/header') %>
<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col">
      <h2 class="page-title">Job Templates</h2>
      <div class="text-muted mt-1">Command yang boleh dijalankan runner</div>
    </div>
  </div>
</div>

<div class="card mt-3">
  <div class="table-responsive">
    <table class="table card-table table-vcenter">
      <thead><tr><th>Name</th><th>Project</th><th>Command</th><th>Timeout</th><th></th></tr></thead>
      <tbody>
      <% templates.forEach(function(t){ %>
        <tr>
          <td><%= t.name %></td>
          <td><%= t.project %></td>
          <td><code><%= t.command_id %></code></td>
          <td><%= t.timeout_sec %>s</td>
          <td class="text-end">
            <form method="post" action="/templates/<%= t.id %>/run" class="m-0">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>"/>
              <button class="btn btn-sm btn-primary">Run</button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('partials/footer') %>
