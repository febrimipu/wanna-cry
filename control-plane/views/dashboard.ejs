<%- include('partials/header') %>
<div class="page-header d-print-none">
  <div class="row align-items-center">
    <div class="col">
      <h2 class="page-title">Dashboard</h2>
      <div class="text-muted mt-1">Ringkasan job Docker Compose</div>
    </div>
    <div class="col-auto ms-auto">
      <a href="/templates" class="btn btn-primary">Run template</a>
    </div>
  </div>
</div>

<div class="row row-cards mt-3">
  <% if (!counts.length) { %>
    <div class="col-12"><div class="alert alert-info">Belum ada job run.</div></div>
  <% } %>
  <% counts.forEach(function(c){ %>
    <div class="col-sm-6 col-lg-3">
      <div class="card">
        <div class="card-body">
          <div class="subheader"><%= c.status %></div>
          <div class="h1 mb-0"><%= c.count %></div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<% if (stats) { %>
<%
  function fmtBytes(n){
    if (!n) return '0 B';
    var units = ['B','KB','MB','GB'];
    var i = 0;
    while (n >= 1024 && i < units.length - 1) { n = n/1024; i++; }
    return n.toFixed(n >= 10 || i === 0 ? 0 : 1) + ' ' + units[i];
  }
%>
<div class="card mt-4">
  <div class="card-header d-flex align-items-center">
    <h3 class="card-title mb-0">Log &amp; DB guardrails</h3>
    <% if (user && user.role === 'admin') { %>
      <form method="post" action="/admin/maintenance" class="ms-auto m-0"
            onsubmit="return confirm('Jalankan maintenance sekarang? Trim log, hapus log lama, vacuum DB.');">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>"/>
        <button class="btn btn-sm btn-outline-secondary">Run maintenance now</button>
      </form>
    <% } %>
  </div>
  <div class="card-body">
    <div class="row g-3">
      <div class="col-sm-6 col-lg-3">
        <div class="subheader">DB size</div>
        <div class="h3 mb-0"><%= fmtBytes(stats.dbSizeBytes) %></div>
        <div class="text-muted small">WAL <%= fmtBytes(stats.walSizeBytes) %></div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="subheader">Total runs</div>
        <div class="h3 mb-0"><%= stats.totalRuns %></div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="subheader">Total log rows</div>
        <div class="h3 mb-0"><%= stats.totalLogRows %></div>
      </div>
      <div class="col-sm-6 col-lg-3">
        <div class="subheader">Retention</div>
        <div class="small">
          Max <%= stats.config.maxLogLinesPerRun %> baris/run<br/>
          Log <%= stats.config.logRetentionDays %> hari<br/>
          Run <%= stats.config.runRetentionDays %> hari<br/>
          Interval <%= stats.config.intervalHours %>j
        </div>
      </div>
    </div>
  </div>
</div>
<% } %>

<div class="card mt-4">
  <div class="card-header"><h3 class="card-title">Recent runs</h3></div>
  <div class="table-responsive">
    <table class="table card-table table-vcenter">
      <thead><tr><th>Run</th><th>Project</th><th>Command</th><th>Status</th><th>Created</th></tr></thead>
      <tbody>
      <% recentRuns.forEach(function(r){ %>
        <tr>
          <td><a href="/runs/<%= r.id %>"><%= r.id %></a></td>
          <td><%= r.project %></td>
          <td><code><%= r.command_id %></code></td>
          <td><span class="badge bg-blue-lt"><%= r.status %></span></td>
          <td><%= r.created_at %></td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('partials/footer') %>
